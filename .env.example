# Narrations — environment variables
# Copy this file to `.env.local` for local dev, and set the same keys in your
# host's dashboard (Vercel / Netlify) for production. Never commit real values.

# --- Notion ( shared token for both databases below ) ---
# One Notion integration token, shared by the contact form and the newsletter.
# Share BOTH databases with this same integration in Notion.
NOTION_TOKEN=

# --- Contact form ( /api/contact ) ---
# Notion database that contact submissions are written to.
NOTION_DATABASE_ID=
# Optional: Slack Incoming Webhook URL to also post a message on each submission.
SLACK_WEBHOOK_URL=

# --- Newsletter subscribe ( /api/subscribe ) — footer + resources page ---
# Notion database that newsletter signups are written to.
# Required columns: "Email" (Title) and "Source" (Select).
NOTION_SUBSCRIBERS_DATABASE_ID=

# --- Book a demo ( /api/book-a-demo, /api/book-a-demo/slots ) ---
# Cal.com API key + the event-type ID for the demo call.
CAL_API_KEY=
CAL_EVENT_TYPE_ID=
